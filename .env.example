# ============================================================================
# Organizer2 – Konfiguration
# Kopiere diese Datei nach ".env" und trage deine Werte ein.
# Ohne gesetzte Integrations-Credentials läuft die App im MOCK-Modus
# (Demo-Daten), damit du alles ausprobieren kannst.
# ============================================================================

# --- Server ---
PORT=3000
# Auf 0.0.0.0 lauschen, damit die App im lokalen Netz auch vom Handy
# erreichbar ist. Auf 127.0.0.1 setzen, wenn nur dieser PC zugreifen soll.
HOST=0.0.0.0

# --- Datenbank (lokale Datei) ---
# Lege diese Datei in deinen OneDrive-Ordner, dann wird sie automatisch
# synchronisiert. Beispiel Windows:
# DATA_FILE=C:\Users\DEINNAME\OneDrive\organizer2\data.json
DATA_FILE=./data/data.json

# --- LLM: Anthropic Claude ---
# API-Key von https://console.anthropic.com
ANTHROPIC_API_KEY=
# Modell zum Einordnen von Mails/Nachrichten/Tickets.
LLM_MODEL=claude-sonnet-4-6
# Modell zum Generieren von E-Mail/Teams-Entwürfen (etwas hochwertiger).
LLM_DRAFT_MODEL=claude-sonnet-4-6

# --- M365 (Microsoft Graph) für Outlook-Mail & Teams ---
# Azure App-Registrierung (Entra ID). Siehe README -> "M365 einrichten".
M365_TENANT_ID=
M365_CLIENT_ID=
M365_CLIENT_SECRET=
# Welches Postfach abgefragt wird (deine UPN/E-Mail).
M365_USER=

# --- JIRA ---
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
# Optionaler JQL-Filter; Standard: dir zugewiesene, offene Tickets.
JIRA_JQL=assignee = currentUser() AND statusCategory != Done

# --- Freshdesk ---
FRESHDESK_DOMAIN=
FRESHDESK_API_KEY=

# --- Sync ---
# Automatischer Sync-Intervall in Minuten (0 = aus, nur manueller Sync).
SYNC_INTERVAL_MINUTES=0
